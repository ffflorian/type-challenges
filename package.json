{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@evilmartians/lefthook": "2.1.4",
    "@ffflorian/eslint-config": "0.13.4",
    "@ffflorian/prettier-config": "0.6.4",
    "@type-challenges/utils": "0.1.1",
    "@types/node": "~24",
    "eslint": "10.1.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-oxlint": "1.57.0",
    "eslint-plugin-perfectionist": "5.7.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "oxlint": "1.57.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2"
  },
  "license": "GPL-3.0",
  "main": "index.js",
  "name": "@ffflorian/type-challenges",
  "packageManager": "yarn@4.13.0",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "repository": "https://github.com/ffflorian/type-challenges.git",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dist": "yarn clean && yarn build",
    "fix": "yarn fix:ts && yarn fix:other",
    "fix:other": "yarn prettier --write",
    "fix:ts": "yarn lint:ts:oxlint --fix && yarn lint:ts:eslint --fix",
    "lint": "yarn lint:other && yarn lint:ts",
    "lint:other": "yarn prettier --list-different",
    "lint:ts": "yarn lint:ts:oxlint && yarn lint:ts:eslint",
    "lint:ts:eslint": "eslint .",
    "lint:ts:oxlint": "oxlint --ignore-path .gitignore .",
    "prettier": "prettier \"*.{json,md,yml}\"",
    "test": "tsc --noEmit"
  },
  "version": "1.0.0"
}
