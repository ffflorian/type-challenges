{
  "compilerOptions": {
    "alwaysStrict": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "outDir": "dist",
    "rootDir": "challenges",
    "sourceMap": true,
    "strict": true,
    "strictFunctionTypes": true,
    "target": "es2020",
    "types": []
  },
  "exclude": ["dist", "node_modules", "spec", "eslint.config.ts"]
}
